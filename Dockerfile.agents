FROM node:22-alpine AS build

WORKDIR /app
RUN corepack enable
COPY packages/agents/package.json ./package.json
RUN printf 'onlyBuiltDependencies:\n  - esbuild\n' > pnpm-workspace.yaml \
  && pnpm install --no-frozen-lockfile
COPY packages/agents/tsconfig.json ./tsconfig.json
COPY packages/agents/src ./src
COPY packages/agents/characters ./characters
RUN pnpm build && pnpm prune --prod

FROM node:22-alpine

WORKDIR /app
ENV NODE_ENV=production
COPY --from=build /app/package.json ./
COPY --from=build /app/node_modules ./node_modules
COPY --from=build /app/dist ./dist
COPY --from=build /app/characters ./characters

EXPOSE 8787
CMD ["node", "dist/server.js"]
