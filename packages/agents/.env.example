PORT=8787

# ── Durable runtime storage (required) ─────────────────────────
# Neon pooled connection string. Keep this on the agents service only;
# do not expose it in NEXT_PUBLIC_* variables or the web app.
DATABASE_URL=

# ── OpenRouter (required for debates) ──────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
# Optional OpenRouter attribution headers
OPENROUTER_HTTP_REFERER=https://multimarkets.local
OPENROUTER_APP_TITLE=MultiMarkets

# Coinbase price oracle
COINBASE_ORACLE_URL=https://api.coinbase.com/v2

# HashKey RPC + APRO feeds (optional eth_call pricing)
HASHKEY_RPC_URL=https://testnet.hsk.xyz
APRO_USDT_USD=0x823d7f90f7A3498DB6595886b6B5dC95E6B0B7f3
APRO_USDC_USD=0x244Ce344df8837c9d938867E2Ffbf0E4B0169B56

# HSP agent fee settlement
HSP_COORDINATOR_URL=

# Settlement payload HMAC
SETTLEMENT_HMAC_SECRET=
