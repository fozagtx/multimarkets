# DO NOT put PRIVATE_KEY here.
# Deploy with: npm run deploy:testnet:sync  (prompts for key, not saved)

# HashKey TESTNET only (chain 133) — faucet: https://faucet.hsk.xyz/faucet
HASHKEY_TESTNET_RPC=https://testnet.hsk.xyz

# Optional: existing collateral; otherwise deploy mints TestnetUSDT (tUSDT)
# COLLATERAL_TOKEN=
# DEPLOY_TESTNET_USDT=1

# Optional explorer / oracle signer (addresses only — not private keys)
HASHKEY_EXPLORER_API_KEY=
COINBASE_ORACLE_SIGNER=

REPORT_GAS=false

 
