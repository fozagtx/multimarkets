{
  "name": "@multimarkets/contracts",
  "version": "1.0.0",
  "private": true,
  "description": "MultiMarkets Solidity smart contracts - gamified prediction markets on HashKey Chain",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "clean": "hardhat clean",
    "deploy:testnet": "hardhat run scripts/deploy.ts --network hashkeyTestnet",
    "deploy:testnet:sync": "bash scripts/deploy-testnet.sh",
    "probe:testnet": "hardhat run scripts/probe-testnet.ts --network hashkeyTestnet",
    "deploy:mainnet": "echo 'Refusing mainnet by default. Use ALLOW_MAINNET=1 npm run deploy:mainnet:force' && exit 1",
    "deploy:mainnet:force": "ALLOW_MAINNET=1 hardhat run scripts/deploy.ts --network hashkey",
    "node": "hardhat node",
    "coverage": "hardhat coverage",
    "typechain": "hardhat typechain",
    "build": "hardhat compile"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.8",
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.12",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.12",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.10.5",
    "chai": "^4.5.0",
    "dotenv": "^16.4.7",
    "ethers": "^6.13.4",
    "hardhat": "^2.22.17",
    "hardhat-gas-reporter": "^1.0.10",
    "solidity-coverage": "^0.8.14",
