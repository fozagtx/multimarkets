{
  "name": "multimarkets",
  "version": "0.1.0",
  "private": true,
  "description": "MultiMarkets - gamified prediction markets with AI persona debates on HashKey Chain",
  "scripts": {
    "dev": "pnpm --filter @multimarkets/web dev",
    "dev:agents": "pnpm --filter @multimarkets/agents dev",
    "dev:all": "pnpm -r --parallel --filter @multimarkets/web --filter @multimarkets/agents dev",
    "build": "pnpm -r build",
    "build:contracts": "pnpm --filter @multimarkets/contracts build",
    "test:contracts": "pnpm --filter @multimarkets/contracts test",
    "lint": "pnpm -r lint"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.32.1"
}
